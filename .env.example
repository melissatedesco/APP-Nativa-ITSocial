# Copia questo file in .env e imposta l'URL del tuo backend.
# Il file .env NON deve essere committato (è nel .gitignore).
#
# Esempi:
#   Dispositivo fisico  → http://192.168.1.XXX:8080   (IP LAN del PC con il backend)
#   Emulatore Android   → http://10.0.2.2:8080
#   Simulatore iOS      → http://localhost:8080
#
EXPO_PUBLIC_API_URL=http://TUO_IP_LAN:8080
